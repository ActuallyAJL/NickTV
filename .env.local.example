# Copy this file to `.env.local` (which is gitignored) and fill in your values.
# Create React App loads `.env.local` for `npm start` / `npm run build`.
#
# WARNING: REACT_APP_* values are embedded into the public client bundle at build time.
# Only use a Plex token/collection you're comfortable being publicly readable.

# Plex server base URL. Local dev can use http://<ip>:<port>.
REACT_APP_PLEX_URL=http://your-plex-host:32400

# Plex X-Plex-Token.
REACT_APP_PLEX_TOKEN=your-x-plex-token

# Movie library section id on your Plex server.
REACT_APP_MOVIE_LIB_ID=1

# Optional: override the dev data API (defaults to json-server on http://localhost:8088).
# REACT_APP_DB_URL=http://localhost:8088
